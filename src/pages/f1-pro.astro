---
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from './components/Navigation.astro';
---

<MainLayout title="F1 Pro | Ultra Velocity">
  <Navigation />

  <div class="hero">
    <div class="hero-img"></div>
    <div class="hero-overlay"></div>
    <h1>AERO</h1>
    <div class="stats-bar">
      <span><b>350</b> KM/H</span>
      <span><b>1.8</b> SEC PIT</span>
      <span><b>1000+</b> BHP</span>
    </div>
  </div>

  <main class="container">
    <div class="glow-blob" style="top: 120%; left: -10%;"></div>

    <section class="grid-section">
      <div class="text-content">
        <h2>The Beauty of Fluid Dynamics</h2>
        <p>
          In the airflow at 300km/h, the race car is not just a machine, but a precise physical model.
          Using **CFD (Computational Fluid Dynamics)**, every millimeter of the sidepod edge undergoes billions of partial differential equation calculations,
          aiming to convert turbulence into downforce, allowing the car to fight gravity in corners.
        </p>
      </div>
      <div class="tech-specs">
        <div><span>DRS Drag Reduction System</span> <span>ACTIVE</span></div>
        <div><span>Front Wing Angle</span> <span>12.5°</span></div>
        <div><span>Diffuser Efficiency</span> <span>+18.3%</span></div>
        <div><span>Downforce Level</span> <span>ULTRA</span></div>
      </div>
    </section>

    <section class="grid-section" style="grid-template-columns: 0.8fr 1.2fr;">
      <div class="tech-specs">
        <div style="color: var(--accent-blue);">// NEURAL NETWORK SIMULATION</div>
        <div><span>Data Points/Second</span> <span>1.2M</span></div>
        <div><span>Pit Stop Probability Prediction</span> <span>89.4%</span></div>
        <div><span>Tire Degradation Model</span> <span>VALID</span></div>
      </div>
      <div class="text-content">
        <h2>Digital Twin and AI Decision Making</h2>
        <p>
          Modern F1 racing is a battle of computing power. Based on **Reinforcement Learning** strategy models,
          real-time processing of thousands of sensors' feedback. We're not just racing, we're training a digital soul in real-time that can predict every overtaking window.
        </p>
      </div>
    </section>
  </main>

  <footer style="text-align: center; padding: 100px; color: #333; letter-spacing: 10px;">
    LIMITLESS ENGINEERING
  </footer>

  <style>
    /* --- Geek Aesthetic Definition --- */
    @font-face {
      font-family: 'TechFont';
      src: local('Orbitron'), local('Rajdhani'), sans-serif;
    }

    :root {
      --f1-red: #ff1801;
      --deep-space: #080808;
      --accent-blue: #00f3ff;
      --text-gray: #a0a0a0;
      --glass: rgba(255, 255, 255, 0.03);
    }

    body {
      margin: 0;
      background-color: var(--deep-space);
      color: #ffffff;
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      overflow-x: hidden;
      scroll-behavior: smooth;
    }

    /* --- 滚动动画核心逻辑 (现代浏览器支持) --- */
    @keyframes reveal {
      from { opacity: 0; transform: translateY(100px) scale(0.9); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }

    @keyframes image-zoom {
      from { transform: scale(1.2); }
      to { transform: scale(1); }
    }

    /* --- 全屏首屏 --- */
    .hero {
      position: relative;
      height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      overflow: hidden;
    }

    .hero-img {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      background: url('/f1.jpg') center/cover no-repeat;
      z-index: -2;
      animation: image-zoom linear forwards;
      animation-timeline: scroll();
      animation-range: start 0% end 50%;
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, rgba(8,8,8,0.2) 0%, var(--deep-space) 95%);
      z-index: -1;
    }

    .hero h1 {
      font-family: 'TechFont', sans-serif;
      font-size: clamp(4rem, 15vw, 12rem);
      font-weight: 900;
      margin: 0;
      letter-spacing: -0.05em;
      text-transform: uppercase;
      /* 镂空描边效果 */
      -webkit-text-stroke: 1px rgba(255,255,255,0.3);
      color: transparent;
      transition: all 0.5s ease;
    }

    .hero h1:hover {
      -webkit-text-stroke: 1px var(--f1-red);
      color: white;
      text-shadow: 0 0 30px var(--f1-red);
    }

    /* --- 参数仪表盘 --- */
    .stats-bar {
      position: absolute;
      bottom: 50px;
      display: flex;
      gap: 60px;
      text-transform: uppercase;
      font-size: 0.8rem;
      letter-spacing: 3px;
      color: var(--accent-blue);
    }

    .stats-bar span b { font-size: 1.2rem; color: #fff; margin-right: 5px; }

    /* --- 内容排版 --- */
    .container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 100px 20px;
    }

    .grid-section {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 100px;
      align-items: center;
      margin-bottom: 200px;
      /* 这里的动画是关键：滚动时自动触发 */
      view-timeline-name: --section;
      view-timeline-axis: block;
      animation: reveal linear forwards;
      animation-timeline: --section;
      animation-range: entry 10% cover 40%;
    }

    .text-content h2 {
      font-size: 3rem;
      font-weight: 800;
      margin-bottom: 20px;
      background: linear-gradient(90deg, #fff, var(--text-gray));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .text-content p {
      font-size: 1.1rem;
      color: var(--text-gray);
      line-height: 1.8;
    }

    .tech-specs {
      font-family: monospace;
      background: var(--glass);
      padding: 30px;
      border-left: 2px solid var(--f1-red);
      font-size: 0.9rem;
    }

    .tech-specs div {
      display: flex;
      justify-content: space-between;
      padding: 10px 0;
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    /* --- 动态光效装饰 --- */
    .glow-blob {
      position: absolute;
      width: 400px; height: 400px;
      background: radial-gradient(circle, rgba(255,24,1,0.1) 0%, transparent 70%);
      z-index: -1;
      filter: blur(50px);
    }

    /* --- 额外优化特效 --- */
    .hero::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: radial-gradient(circle at 20% 80%, rgba(255, 24, 1, 0.1) 0%, transparent 50%),
                  radial-gradient(circle at 80% 20%, rgba(0, 243, 255, 0.1) 0%, transparent 50%);
      z-index: -1;
      animation: backgroundShift 10s ease-in-out infinite alternate;
    }

    @keyframes backgroundShift {
      0% { opacity: 0.5; }
      100% { opacity: 1; }
    }

    .grid-section:hover .text-content h2 {
      background: linear-gradient(90deg, var(--f1-red), var(--accent-blue));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: textGlow 2s ease-in-out infinite alternate;
    }

    @keyframes textGlow {
      from { text-shadow: 0 0 10px rgba(255, 24, 1, 0.5); }
      to { text-shadow: 0 0 20px rgba(255, 24, 1, 1); }
    }

    .tech-specs:hover {
      background: rgba(255, 255, 255, 0.08);
      transform: translateX(10px);
      transition: all 0.3s ease;
    }

    footer {
      position: relative;
      overflow: hidden;
    }

    footer::after {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 24, 1, 0.1), transparent);
      animation: footerShine 3s ease-in-out infinite;
    }

    @keyframes footerShine {
      0% { left: -100%; }
      100% { left: 100%; }
    }
  </style>
</MainLayout>